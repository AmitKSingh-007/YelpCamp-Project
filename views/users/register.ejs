<% layout('layouts/boilerplate') -%>

<link rel="stylesheet" href="/stylesheets/auth.css">

<div class="container d-flex justify-content-center align-items-center min-vh-100 py-5">

  <div class="card shadow-lg border-0 rounded-4 auth-card">
    <div class="card-body p-5">

      <div class="text-center mb-4">

        <i class="bi bi-person-plus-fill display-3 text-success mb-3" aria-hidden="true"></i>

        <h1 class="fw-bold mb-2">
          Create Account
        </h1>

        <p class="text-muted mb-0">
          Join us and start your adventure today
        </p>

      </div>

      <form action="/register" method="POST" class="validated-form" novalidate>

        <div class="mb-3">
          <label class="form-label fw-semibold" for="username">
            Username
          </label>

          <input class="form-control form-control-lg" type="text" id="username" name="user[username]" placeholder="Choose a username" autocomplete="username" required>

          <div class="invalid-feedback">
            Please enter a username.
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold" for="email">
            Email Address
          </label>

          <input class="form-control form-control-lg" type="email" id="email" name="user[email]" placeholder="Enter your email" autocomplete="email" required>

          <div class="invalid-feedback">
            Please enter a valid email address.
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label fw-semibold" for="password">
            Password
          </label>

          <input class="form-control form-control-lg" type="password" id="password" name="user[password]" placeholder="Create a password" autocomplete="new-password" minlength="8" required>

          <div class="invalid-feedback">
            Password must be at least 8 characters long.
          </div>
        </div>

        <div class="d-grid">
          <button class="btn btn-success btn-lg rounded-3">
            Create Account
          </button>
        </div>

      </form>

      <hr class="my-4">

      <div class="text-center">
        <p class="text-muted mb-0">
          Already have an account?
          <a href="/login" class="text-decoration-none fw-semibold">
            Sign in here
          </a>
        </p>
      </div>

    </div>
  </div>

</div>