<% layout('layouts/boilerplate') -%>

<link rel="stylesheet" href="/stylesheets/home.css">

<section class="py-5 mb-4">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-7">
        <h1 class="display-4 fw-bold">
          Discover Your Next Outdoor Adventure
        </h1>
        <p class="lead text-muted mt-4 hero-text">
          Discover amazing campgrounds, share unforgettable experiences,
          and inspire fellow campers to explore the outdoors.
        </p>
        <div class="mt-5 d-flex gap-3 flex-wrap">
          <a href="/campgrounds" class="btn btn-success btn-lg hero-btn">
            Explore Campgrounds →
          </a>
          <a href="/campgrounds/new" class="btn btn-outline-success btn-lg hero-btn">
            Share a Campground
          </a>
        </div>
      </div>
      <div class="col-lg-5 d-flex justify-content-center mt-4 mt-lg-0">
        <img src="/images/home.webp" class="hero-image" alt="A peaceful campsite at sunset" loading="eager" decoding="async">
      </div>
    </div>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <p class="text-success text-uppercase fw-semibold small mb-2">
        Discover
      </p>
      <h2 class="display-5 fw-bold mb-3"> Adventure Starts Here </h2>
      <p class="lead text-muted mx-auto section-description">
        Browse handpicked campgrounds loved by our community and find the perfect destination for your
        next outdoor adventure.
      </p>
    </div>

    <div class="row g-4">
      <% if(featuredCampgrounds.length > 0) { %>
      <% featuredCampgrounds.forEach(campground=> { %>
      <div class="col-lg-4 col-md-6">
        <a href="/campgrounds/<%= campground._id %>" class="featured-card">
          <div class="featured-card-image">
            <% if (campground.images && campground.images.length> 0) { %>
            <img src="<%= campground.images[0].url %>" alt="Photo of <%= campground.title %>">
            <% } else { %>
            <img src="/images/fallback-camp.webp" alt="Campground placeholder image">
            <% } %>
          </div>
          <div class="featured-card-content">
            <h3>
              <%= campground.title %>
            </h3>
            <p class="d-flex align-items-center gap-1"><i class="bi bi-geo-alt-fill text-danger"></i>
              <%= campground.location %>
            </p>
          </div>
        </a>
      </div>
      <% }) %>
      <% } else { %>
      <div class="text-center py-5">
        <p class="text-muted">
          No featured campgrounds available yet.
        </p>
      </div>
      <% } %>
    </div>
  </div>
</section>

<section class="py-5 bg-light rounded-4 my-5">
  <div class="container text-center py-4">
    <p class="text-success text-uppercase fw-semibold small mb-2">Features</p>
    <h2 class="display-5 fw-bold mb-5">Why Choose YelpCamp?</h2>

    <div class="row g-4 justify-content-center">
      <div class="col-md-4">
        <div class="feature-card p-4 h-100">
          <div class="feature-icon mb-3 text-success"><i class="bi bi-map"></i></div>
          <h4 class="fw-bold mb-2">Interactive Maps</h4>
          <p class="text-muted mb-0">Discover campgrounds around the world with an interactive map.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card p-4 h-100">
          <div class="feature-icon mb-3 text-success"><i class="bi bi-camera"></i></div>
          <h4 class="fw-bold mb-2">Share Your Adventures</h4>
          <p class="text-muted mb-0">Upload photos and inspire other campers.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card p-4 h-100">
          <div class="feature-icon mb-3 text-success"><i class="bi bi-chat-square-heart"></i></div>
          <h4 class="fw-bold mb-2">Community Reviews</h4>
          <p class="text-muted mb-0">Read honest reviews and share your own experiences.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-5 my-5 text-center bg-success text-white rounded-4 shadow-sm cta-banner">
  <div class="container py-4">
    <h2 class="display-5 fw-bold mb-3">Ready for Your Next Adventure?</h2>
    <p class="lead mb-4 opacity-90 mx-auto cta-description">
      Join thousands of campers discovering new destinations every day.
    </p>
    <a href="/campgrounds" class="btn btn-light btn-lg rounded-pill px-5 fw-semibold text-success shadow-sm hover-grow">
      Explore Campgrounds
    </a>
  </div>
</section>