<% layout('layouts/boilerplate') -%>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet.markercluster@1.5.3/dist/MarkerCluster.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css">

<link rel="stylesheet" href="/stylesheets/campIdx.css">
<link rel="stylesheet" href="/stylesheets/map.css">

<div class="py-5">

  <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4 mb-5">

    <div>

      <h1 class="display-5 fw-bold d-flex align-items-center gap-2 mb-2">
        <i class="bi bi-tree-fill text-success"></i>
        Explore Campgrounds
      </h1>

      <p class="text-muted mb-3">
        Discover incredible outdoor destinations shared by campers around the world.
      </p>

      <span class="badge bg-success-subtle text-success-emphasis fs-6 px-3 py-2 rounded-pill">
        <i class="bi bi-geo-alt-fill me-1"></i>
        <%= campgrounds.length %>
        <%= campgrounds.length === 1 ? "Campground" : "Campgrounds" %>
      </span>

    </div>

    <a href="/campgrounds/new" class="btn btn-success btn-lg rounded-pill px-5 d-inline-flex align-items-center gap-2 shadow-sm">

      <i class="bi bi-plus-circle"></i>
      Add Campground

    </a>

  </div>

  <div id="map" class="mb-5"></div>

  <% if (campgrounds.length === 0) { %>

  <div class="card border-0 shadow-sm rounded-4 py-5 text-center">

    <div class="display-1 text-success mb-3">
      <i class="bi bi-tree"></i>
    </div>

    <h3 class="fw-bold">
      No Campgrounds Yet
    </h3>

    <p class="text-muted mb-4">
      Be the first explorer to share an amazing destination.
    </p>

    <a href="/campgrounds/new" class="btn btn-success rounded-pill px-5">

      <i class="bi bi-plus-circle me-2"></i>
      Add Campground

    </a>

  </div>

  <% } else { %>

  <% for (let campground of campgrounds) { %>
  <div class="card shadow-sm border-0 rounded-4 mb-4 campground-card overflow-hidden">
    <div class="row g-0">

      <div class="col-md-4">
        <% if (campground.images.length> 0) { %>
        <img src="<%= campground.images[0].url %>" class="img-fluid h-100 w-100 object-fit-cover campground-image" alt="Photo of <%= campground.title %>">
        <% } else { %>
        <div class="bg-light h-100 d-flex flex-column justify-content-center align-items-center text-muted  image-placeholder">

          <i class="bi bi-image fs-1 mb-3"></i>

          <h6 class="mb-1">
            No Image
          </h6>

          <small>
            Upload one to showcase this campground
          </small>

        </div>
        <% } %>
      </div>

      <div class="col-md-8">
        <div class="card-body p-4 h-100 d-flex flex-column justify-content-center">
          <div class="d-flex justify-content-between align-items-start mb-3">

            <h3 class="card-title fw-bold mb-0">
              <%= campground.title %>
            </h3>

            <span class="badge bg-success rounded-pill px-3 py-2 fw-semibold">
              $<%= campground.price.toFixed(2) %><small>/ night</small>
            </span>

          </div>
          <p class="card-text text-muted">
            <%= campground.description.length > 160
              ? campground.description.substring(0, 160) + "..."
              : campground.description %>
          </p>
          <hr class="my-3 opacity-25">
          <p class="text-secondary mb-3">

            <i class="bi bi-geo-alt-fill text-danger me-2"></i>

            <%= campground.location %>

          </p>
          <a href="/campgrounds/<%= campground._id %>" class="btn btn-outline-success rounded-pill px-4 py-2 align-self-start">

            View Details
            <i class="bi bi-arrow-right ms-2"></i>

          </a>
        </div>
      </div>

    </div>
  </div>
  <% } %>

  <% } %>

  <script>
    const mapData = <%- JSON.stringify(mapData) %>;
    const maptilerApiKey = "<%= process.env.MAPTILER_API_KEY %>";
  </script>
  <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
  <script src="/javascripts/clusterMap.js"></script>

</div>