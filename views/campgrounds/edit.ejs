<% layout('layouts/boilerplate') -%>
  <link rel="stylesheet" href="/stylesheets/campnew.css">

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <div class="card shadow border-0">
          <div class="card-body p-5">

            <h1 class="text-center mb-4 d-flex align-items-center justify-content-center gap-2">
              <i class="bi bi-pencil-square text-primary"></i>
              Edit Campground
            </h1>
            <p class="text-center text-muted mb-5">
              Update your campground details below.
            </p>

            <form action="/campgrounds/<%= campground._id %>?_method=PUT" method="POST" novalidate
              class="validated-form" enctype="multipart/form-data">

              <div class="mb-4">
                <label class="form-label fw-bold" for="title">Campground Title</label>
                <input class="form-control" type="text" name="campground[title]" id="title"
                  value="<%= campground.title %>" placeholder="Enter campground title" required>
                <div class="valid-feedback">
                  Looks good!
                </div>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold" for="location">Location</label>
                <input class="form-control" type="text" name="campground[location]" id="location"
                  value="<%= campground.location %>" placeholder="e.g. Yosemite National Park" required>
                <div class="valid-feedback">
                  Looks good!
                </div>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold" for="price">Price Per Night</label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" class="form-control" id="price" name="campground[price]"
                    value="<%= campground.price %>" min="0" step="0.01" placeholder="0.00" required>
                  <div class="valid-feedback">
                    Looks good!
                  </div>
                </div>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold" for="description">Description</label>
                <textarea class="form-control" name="campground[description]" id="description" rows="5"
                  placeholder="Tell visitors about this campground..." required><%= campground.description %></textarea>
                <div class="valid-feedback">
                  Looks good!
                </div>
              </div>

              <h4 class="mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-images text-secondary"></i>
                Current Images
              </h4>
              <div class="mb-4">
                <div class="row">
                  <% campground.images.forEach(image=> { %>
                    <div class="col-md-3 mb-3">
                      <div class="card">
                        <img src="<%= image.thumbnail %>" class="card-img-top img-fluid" alt="Campground Image"
                          style="height: 180px; object-fit: cover;">
                        <div class="card-body">
                          <div class="form-check d-flex align-items-center">
                            <input class="form-check-input me-2" type="checkbox" name="deleteImages"
                              value="<%= image.filename %>" id="image-<%= image._id %>">
                            <label class="form-check-label" for="image-<%= image._id %>">
                              Delete
                            </label>
                          </div>
                        </div>
                      </div>
                    </div>
                    <% }) %>
                </div>
              </div>

              <h4 class="mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-cloud-upload text-success"></i>
                Upload New Images
              </h4>
              <div class="mb-4">
                <label class="form-label fw-semibold" for="images">Images</label>
                <input class="form-control form-control-lg" type="file" name="images" id="images" multiple>
              </div>

              <div class="d-flex gap-2">
                <button class="btn btn-primary">
                  Update Campground
                </button>
                <a href="/campgrounds/<%= campground._id %>" class="btn btn-outline-secondary">
                  Cancel
                </a>
              </div>

            </form>

          </div>
        </div>

      </div>
    </div>
  </div>