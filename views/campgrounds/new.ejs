<% layout('layouts/boilerplate') -%>
<link rel="stylesheet" href="/stylesheets/campForm.css">

<div class="py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="text-center mb-4">
        <h1 class="display-5 fw-bold d-flex align-items-center justify-content-center gap-2">
          <i class="bi bi-tree-fill text-success"></i> Create New Campground
        </h1>
        <p class="text-muted">
          Share an amazing camping destination with the community.
        </p>
      </div>

      <div class="card shadow border-0">
        <div class="card-body p-4 p-md-5">

          <form action="/campgrounds" method="POST" novalidate class="validated-form" enctype="multipart/form-data">

            <div class="mb-4">
              <label class="form-label fw-semibold" for="title">Campground Title</label>
              <input class="form-control form-control-lg" type="text" name="campground[title]" id="title" placeholder="e.g. Yosemite Valley Camp" required>
              <div class="invalid-feedback">
                Please enter a campground title.
              </div>
            </div>

            <div class="mb-4">
              <label class="form-label fw-semibold" for="images">Images</label>
              <input class="form-control form-control-lg" type="file" name="images" accept="image/jpeg,image/png,image/webp" id="images" multiple>
              <div class="form-text">
                Upload up to 5 images (PNG, JPG, or WEBP). Maximum 5 MB per image.
              </div>
            </div>

            <div class="mb-4">
              <label class="form-label fw-semibold" for="location">Location</label>
              <input class="form-control form-control-lg" type="text" name="campground[location]" id="location" placeholder="e.g. Yosemite National Park, California, USA" required>
              <div class="invalid-feedback">
                Please enter a campground location.
              </div>
            </div>

            <div class="mb-4">
              <label class="form-label fw-semibold" for="price">Price Per Night</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" min="0" step="0.01" class="form-control form-control-lg" name="campground[price]" id="price" placeholder="49.99" required>
              </div>
              <div class="invalid-feedback">
                Please enter a campground price.
              </div>
            </div>

            <div class="mb-4">
              <label class="form-label fw-semibold" for="description">Description</label>
              <textarea class="form-control" rows="5" name="campground[description]" id="description" placeholder="Describe the campground, nearby attractions, amenities, and what makes it special..." required></textarea>
              <div class="invalid-feedback">
                Please enter a campground description.
              </div>
            </div>

            <div class="d-grid gap-2">
              <button class="btn btn-success btn-lg">
                Publish Campground
              </button>
              <a href="/campgrounds" class="btn btn-outline-secondary">
                Cancel
              </a>
            </div>

          </form>

        </div>
      </div>

    </div>
  </div>
</div>