<% layout('layouts/boilerplate') -%>
<link rel="stylesheet" href="/stylesheets/stars.css">
<link rel="stylesheet" href="/stylesheets/showReview.css">
<link rel="stylesheet" href="/stylesheets/map.css">

<div class="container py-4">
  <div class="row g-4">

    <div class="col-lg-8">
      <div class="card shadow-sm border-0">

        <% if(campground.images.length> 0) { %>
        <div id="campgroundCarousel" class="carousel slide carousel-fade">
          <div class="carousel-inner">
            <% campground.images.forEach((image, index)=> { %>
            <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
              <img src="<%= image.url %>" class="d-block w-100" alt="<%= campground.title %>" style="height:450px; object-fit:cover;">
            </div>
            <% }) %>
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#campgroundCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#campgroundCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
        <% } else { %>
        <div class="d-flex flex-column justify-content-center align-items-center bg-light" style="height:450px;">
          <i class="bi bi-tree text-secondary mb-2" style="font-size: 4rem;"></i>
          <h5 class="text-muted">No Images Available</h5>
        </div>
        <% } %>

        <div class="card-body">
          <h2 class="fw-bold mb-3">
            <%= campground.title %>
          </h2>
          <p class="text-muted">
            <%= campground.description %>
          </p>
        </div>

        <ul class="list-group list-group-flush">
          <li class="list-group-item d-flex align-items-center gap-2">
            <i class="bi bi-geo-alt-fill text-danger"></i>
            <span><strong>Location:</strong>
              <%= campground.location %>
            </span>
          </li>
          <li class="list-group-item d-flex align-items-center gap-2">
            <i class="bi bi-person-fill text-primary"></i>
            <span><strong>Submitted by:</strong>
              <%= campground.author.username %>
            </span>
          </li>
          <li class="list-group-item d-flex align-items-center gap-2">
            <i class="bi bi-wallet2 text-success"></i>
            <span><strong>Price:</strong> $<%= campground.price %>/night</span>
          </li>
        </ul>

        <% if(currentUser && campground.author.equals(currentUser)) { %>
        <div class="card-body border-top">
          <a href="/campgrounds/<%= campground._id %>/edit" class="btn btn-warning me-2">Edit</a>
          <form action="/campgrounds/<%= campground._id %>?_method=DELETE" method="POST" class="d-inline">
            <button class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this campground?')">
              Delete
            </button>
          </form>
        </div>
        <% } %>

        <div id="map"></div>

        <script>
          const mapData = <%- JSON.stringify({
                        title: campground.title,
                        location: campground.location,
                        geometry: campground.geometry
                      }) %>;
          const maptilerApiKey = "<%= process.env.MAPTILER_API_KEY %>";
        </script>
        <script src="/javascripts/map.js"></script>

      </div>
    </div>

    <div class="col-lg-4">

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body text-center">
          <h3 class="mb-2 d-flex align-items-center justify-content-center gap-2">
            <i class="bi bi-star-fill text-warning"></i> Reviews
          </h3>
          <h1 class="display-5 fw-bold">
            <%= campground.reviews.length %>
          </h1>
          <small class="text-muted">Total Reviews</small>
          <p class="small text-muted mt-2 mb-0">
            Share experiences and help fellow campers choose wisely.
          </p>
        </div>
      </div>

      <% if(currentUser) { %>
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
          <h4 class="fw-bold mb-3">Share Your Experience</h4>
          <p class="text-muted small">Help other campers by sharing your thoughts.</p>

          <form action="/campgrounds/<%= campground._id %>/reviews" method="POST" class="validated-form" novalidate>
            <div class="mb-3">
              <fieldset class="starability-basic">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating.">
                <input type="radio" id="rate1" name="review[rating]" value="1">
                <label for="rate1">1 star</label>
                <input type="radio" id="rate2" name="review[rating]" value="2">
                <label for="rate2">2 stars</label>
                <input type="radio" id="rate3" name="review[rating]" value="3">
                <label for="rate3">3 stars</label>
                <input type="radio" id="rate4" name="review[rating]" value="4">
                <label for="rate4">4 stars</label>
                <input type="radio" id="rate5" name="review[rating]" value="5">
                <label for="rate5">5 stars</label>
              </fieldset>
            </div>

            <div class="mb-3">
              <textarea name="review[body]" id="body" rows="4" class="form-control" placeholder="What did you like about this campground?" required></textarea>
            </div>

            <button class="btn btn-success w-100 rounded-pill">Post Review</button>
          </form>
        </div>
      </div>
      <% } %>

      <% if(campground.reviews.length> 0) { %>
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Community Reviews</h4>
        <span class="badge bg-success rounded-pill">
          <%= campground.reviews.length %>
        </span>
      </div>

      <% for(let review of campground.reviews) { %>
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">

          <div class="d-flex align-items-center mb-3">
            <div class="rounded-circle bg-success text-white d-flex justify-content-center align-items-center me-3" style="width:45px; height:45px;">
              <%= review.author.username.charAt(0).toUpperCase() %>
            </div>
            <div>
              <h6 class="fw-bold mb-0">
                <%= review.author.username %>
              </h6>
              <small class="text-muted d-block">Adventure Enthusiast</small>
              <% if(review.createdAt) { %>
              <small class="text-muted">
                <%= review.createdAt.toDateString() %>
              </small>
              <% } %>
            </div>
          </div>

          <p class="starability-result mb-3" data-rating="<%= review.rating %>">
            Rated: <%= review.rating %> stars
          </p>

          <hr>

          <p class="mb-3">
            <%= review.body %>
          </p>

          <% if(currentUser && review.author.equals(currentUser)) { %>
          <form action="/campgrounds/<%= campground._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
            <button class="btn btn-outline-danger btn-sm rounded-pill">Delete Review</button>
          </form>
          <% } %>

        </div>
      </div>
      <% } %>
      <% } else { %>
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <div class="text-success mb-3">
            <i class="bi bi-patch-question" style="font-size: 3rem;"></i>
          </div>
          <h5>No Reviews Yet</h5>
          <p class="text-muted mb-0">Be the first camper to share your experience.</p>
        </div>
      </div>
      <% } %>

    </div>

  </div>
</div>