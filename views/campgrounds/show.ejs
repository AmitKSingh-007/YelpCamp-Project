<% layout('layouts/boilerplate') %>

<link rel="stylesheet" href="/stylesheets/stars.css">
<link rel="stylesheet" href="/stylesheets/showReview.css">

<div class="container py-4">

<div class="row g-4">

    <!-- Campground Details -->
    <div class="col-lg-8">

        <div class="card shadow-sm border-0">

            <img
                src="<%= campground.image %>"
                class="card-img-top"
                alt="<%= campground.title %>"
                style="max-height:500px; object-fit:cover;"
            >

            <div class="card-body">

                <h2 class="fw-bold mb-3">
                    <%= campground.title %>
                </h2>

                <p class="text-muted">
                    <%= campground.description %>
                </p>

            </div>

            <ul class="list-group list-group-flush">

                <li class="list-group-item">
                    📍 <strong>Location:</strong>
                    <%= campground.location %>
                </li>

                <li class="list-group-item">
                    👤 <strong>Submitted by:</strong>
                    <%= campground.author.username %>
                </li>

                <li class="list-group-item">
                    💰 <strong>Price:</strong>
                    $<%= campground.price %>/night
                </li>

            </ul>

            <% if(currentUser && campground.author.equals(currentUser)) { %>

            <div class="card-body border-top">

                <a
                    href="/campgrounds/<%= campground._id %>/edit"
                    class="btn btn-warning me-2"
                >
                    Edit
                </a>

                <form
                    action="/campgrounds/<%= campground._id %>?_method=DELETE"
                    method="POST"
                    class="d-inline"
                >
                    <button
                        class="btn btn-danger"
                        onclick="return confirm('Are you sure you want to delete this campground?')"
                    >
                        Delete
                    </button>
                </form>

            </div>

            <% } %>

            <div class="card-footer bg-light text-muted">
                Added recently
            </div>

        </div>

    </div>

    <!-- Reviews Section -->
    <div class="col-lg-4">

        <!-- Review Summary -->
        <div class="card shadow-sm border-0 mb-4">

            <div class="card-body text-center">

                <h3 class="mb-2">⭐ Reviews</h3>

                <h1 class="display-5 fw-bold">
                    <%= campground.reviews.length %>
                </h1>

                <small class="text-muted">
                    Total Reviews
                </small>

                <p class="small text-muted mt-2 mb-0">
                    Share experiences and help fellow campers choose wisely.
                </p>

            </div>

        </div>

        <!-- Review Form -->
        <% if(currentUser) { %>

        <div class="card shadow-sm border-0 mb-4">

            <div class="card-body">

                <h4 class="fw-bold mb-3">
                    Share Your Experience
                </h4>

                <p class="text-muted small">
                    Help other campers by sharing your thoughts.
                </p>

                <form
                    action="/campgrounds/<%= campground._id %>/reviews"
                    method="POST"
                    class="validated-form"
                    novalidate
                >

                    <div class="mb-3">

                        <fieldset class="starability-basic">

                            <input
                                type="radio"
                                id="no-rate"
                                class="input-no-rate"
                                name="review[rating]"
                                value="1"
                                checked
                                aria-label="No rating."
                            >

                            <input type="radio" id="rate1" name="review[rating]" value="1">
                            <label for="rate1">1 star</label>

                            <input type="radio" id="rate2" name="review[rating]" value="2">
                            <label for="rate2">2 stars</label>

                            <input type="radio" id="rate3" name="review[rating]" value="3">
                            <label for="rate3">3 stars</label>

                            <input type="radio" id="rate4" name="review[rating]" value="4">
                            <label for="rate4">4 stars</label>

                            <input type="radio" id="rate5" name="review[rating]" value="5">
                            <label for="rate5">5 stars</label>

                        </fieldset>

                    </div>

                    <div class="mb-3">

                        <textarea
                            name="review[body]"
                            id="body"
                            rows="4"
                            class="form-control"
                            placeholder="What did you like about this campground?"
                        ></textarea>

                    </div>

                    <button class="btn btn-success w-100 rounded-pill">
                        Post Review
                    </button>

                </form>

            </div>

        </div>

        <% } %>

        <!-- Community Reviews -->
        <% if(campground.reviews.length > 0) { %>

        <div class="d-flex justify-content-between align-items-center mb-3">

            <h4 class="mb-0">
                Community Reviews
            </h4>

            <span class="badge bg-success rounded-pill">
                <%= campground.reviews.length %>
            </span>

        </div>

        <% for(let review of campground.reviews) { %>

        <div class="card shadow-sm border-0 mb-3">

            <div class="card-body">

                <div class="d-flex align-items-center mb-3">

                    <div
                        class="rounded-circle bg-success text-white d-flex justify-content-center align-items-center me-3"
                        style="width:45px;height:45px;"
                    >
                        <%= review.author.username.charAt(0).toUpperCase() %>
                    </div>

                    <div>

                        <h6 class="fw-bold mb-0">
                            <%= review.author.username %>
                        </h6>

                        <small class="text-muted">
                            Adventure Enthusiast
                        </small>

                        <% if(review.createdAt) { %>

                        <div>
                            <small class="text-muted">
                                <%= review.createdAt.toDateString() %>
                            </small>
                        </div>

                        <% } %>

                    </div>

                </div>

                <p
                    class="starability-result mb-3"
                    data-rating="<%= review.rating %>"
                >
                    Rated: <%= review.rating %> stars
                </p>

                <hr>

                <p class="mb-3">
                    <%= review.body %>
                </p>

                <% if(currentUser && review.author.equals(currentUser)) { %>

                <form
                    action="/campgrounds/<%= campground._id %>/reviews/<%= review._id %>?_method=DELETE"
                    method="POST"
                >

                    <button
                        class="btn btn-outline-danger btn-sm rounded-pill"
                    >
                        Delete Review
                    </button>

                </form>

                <% } %>

            </div>

        </div>

        <% } %>

        <% } else { %>

        <div class="card shadow-sm border-0">

            <div class="card-body text-center py-5">

                <h1>🏕️</h1>

                <h5>No Reviews Yet</h5>

                <p class="text-muted mb-0">
                    Be the first camper to share your experience.
                </p>

            </div>

        </div>

        <% } %>

    </div>

</div>

</div>
